import java.util.*;
public class printPattern {
    public static void print(int i,int n,int x)
    {
        if(i>n)
        {
            return;
        }
        System.out.print(x+" ");
        print(i+1,n,x*2+3);
        System.out.print(x+" ");
    }
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        print(1,n,3);
    }
}
